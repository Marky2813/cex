// This is your Prisma schema file,
// learn more about it in the docs: https://pris.ly/d/prisma-schema

// Get a free hosted Postgres database in seconds: `npx create-db`

generator client {
  provider = "prisma-client"
  output   = "../generated/prisma" 
}

datasource db {
  provider = "postgresql"
}


model User {
  id  String @id @default(uuid())
  username String @unique
  password String
  usdBal   Float  @default(0)
  usdLock  Float  @default(0)
  usdTotal Float  @default(0)
  order    Order[]
  balance  UserBalance[]
}

model Instrument {
  id String @id @default(uuid())
  name String
  symbol String @unique
  order  Order[]
  balance UserBalance[]
}

model Order {
  id               String @id @default(uuid())
  userId           String 
  instrumentId     String
  amount           Float
  type             Type
  side             Side
  filledQty        Float? @default(0)
  totalQty         Float?  
  status           Status
  createdAt        DateTime @default(now())
  user             User     @relation(fields: [userId], references: [id])
  instrument       Instrument @relation(fields: [instrumentId], references: [id])
  buyfills         Fill[]     @relation("BuyFills")
  sellfills        Fill[]     @relation("SellFills")
}

model Fill {
  id              String @id @default(uuid())
  buyOrderId      String
  sellOrderId     String 
  instrumentId    String
  amount          Float
  qty             Float 
  createdAt       DateTime @default(now())
  buyOrder        Order  @relation("BuyFills", fields:[buyOrderId], references: [id])
  sellOrder       Order  @relation("SellFills", fields:[sellOrderId], references: [id])
  @@unique([buyOrderId, sellOrderId])
}

model UserBalance {
  id                String  @id  @default(uuid())
  userId            String
  instrumentSymbol  String  
  total             Float   @default(0)
  locked            Float   @default(0)
  user              User    @relation(fields: [userId], references: [id])
  instrument        Instrument @relation(fields: [instrumentSymbol], references: [symbol])
  @@unique([userId, instrumentSymbol])
}

 enum Type {
  Limit
  Market
} 

enum Side {
  Buy
  Sell
}

enum Status {
  Pending 
  Partial
  Completed
  Cancelled
}


